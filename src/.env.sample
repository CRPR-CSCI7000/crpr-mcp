# CRPR MCP local environment values for docker compose.
# Keep secrets (for example GitHub tokens/private keys) only in this local file.

# GitHub App configuration (preferred).
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_BOT_USERNAME=CRPR-Reviewer

# PAT fallback (used when GitHub App auth is not configured or fails).
# GITHUB_TOKEN=

# Required when running crpr-mcp directly outside docker compose.
# Docker compose injects this automatically.
# ZOEKT_API_URL=http://localhost:6070

# Optional runtime overrides (defaults are defined in src/config.py).
# MCP_SSE_PORT=8000
# MCP_STREAMABLE_HTTP_PORT=8080
# EXECUTION_TIMEOUT_SECONDS=300
# EXECUTION_STDOUT_MAX_BYTES=32768
# EXECUTION_STDERR_MAX_BYTES=32768
